RewriteEngine On

# Clean URL routes
RewriteRule ^home/?$ index.html [L]
RewriteRule ^recipes/?$ Recipe_Page/index.html [L]
RewriteRule ^meal-plans/?$ Meal_Plans/index.html [L]
RewriteRule ^cuisines/?$ Cuisine_Page/index.html [L]
RewriteRule ^community/?$ Community_Page/index.html [L]

# SEO redirects from old URLs to clean URLs
RewriteRule ^index\.html$ /home [R=301,L]
RewriteRule ^Recipe_Page/index\.html$ /recipes [R=301,L]
RewriteRule ^Meal_Plans/index\.html$ /meal-plans [R=301,L]
RewriteRule ^Cuisine_Page/index\.html$ /cuisines [R=301,L]
RewriteRule ^Community_Page/index\.html$ /community [R=301,L]

# Handle trailing slashes
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)/$ /$1 [R=301,L]