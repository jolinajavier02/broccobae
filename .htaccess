# Clean URL routes
RewriteRule ^home/?$ index.html [L]
RewriteRule ^recipes/?$ Recipe_Page/index.html [L]
RewriteRule ^meal-plan/?$ Meal_Plans/index.html [L]
RewriteRule ^cuisine/?$ Cuisine_Page/index.html [L]
RewriteRule ^community/?$ Community_Page/index.html [L]

# SEO redirects from old URLs to clean URLs
RewriteRule ^index\.html$ /home [R=301,L]
RewriteRule ^Recipe_Page/index\.html$ /recipes [R=301,L]
RewriteRule ^Meal_Plans/index\.html$ /meal-plan [R=301,L]
RewriteRule ^Cuisine_Page/index\.html$ /cuisine [R=301,L]
RewriteRule ^Community_Page/index\.html$ /community [R=301,L]

# Handle trailing slashes
RewriteRule ^([^/]+)/$ /$1 [R=301,L]
=======
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html [L]

# Additional rules for clean URLs and SEO
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^home/?$ index.html [L]
RewriteRule ^recipes/?$ Recipe_Page/index.html [L]
RewriteRule ^meal-plans/?$ Meal_Plans/index.html [L]
RewriteRule ^cuisines/?$ Cuisine_Page/index.html [L]
RewriteRule ^community/?$ Community_Page/index.html [L]

# Redirect old HTML file paths to clean URLs
RewriteCond %{THE_REQUEST} /([^.\s]+)\.html[\s?] [NC]
RewriteRule ^ /%1? [R=301,L]

# Handle trailing slashes
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)/$ /$1 [R=301,L]
